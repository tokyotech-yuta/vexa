# =============================================================================
# Vexa open-core — compose environment. Copy to .env:  cp .env.example .env
# `make all` copies this automatically on first run if .env is absent.
# Infra defaults below are dev-safe; fill the CREDENTIALS block for full function.
# =============================================================================

# --- project + host ports ----------------------------------------------------
COMPOSE_PROJECT_NAME=vexa-v012
API_GATEWAY_HOST_PORT=18056      # API gateway (all docs/SDK calls target this)
ADMIN_API_PORT=18057             # admin-api (mint API keys)
MEETING_API_PORT=18080
RUNTIME_API_PORT=18090
AGENT_API_PORT=18100
TERMINAL_PORT=13000              # the terminal workbench UI → http://localhost:13000
POSTGRES_HOST_PORT=5458
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# --- images ------------------------------------------------------------------
IMAGE_TAG=v012
# v012 tags are the published 0.12-line images. Do NOT fall back to `dev`: the published
# vexaai/vexa-bot:dev on Docker Hub is the older 0.10 line and is INCOMPATIBLE with this stack's
# lifecycle.v1 contract (bots reach `joining` then fail). For a source dev loop, build the bot
# locally with `make -C deploy/compose bot` and point BROWSER_IMAGE at your local tag.
BROWSER_IMAGE=vexaai/vexa-bot:v012
DOCKER_GID=0
LOG_LEVEL=info

# --- database ----------------------------------------------------------------
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres

# --- object store (MinIO) ----------------------------------------------------
MINIO_ROOT_USER=vexa-access-key
MINIO_ROOT_PASSWORD=vexa-secret-key
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# --- stack secrets (CHANGE for any non-local deploy) -------------------------
ADMIN_TOKEN=dev-admin-token                         # admin-api auth; `make all` mints your API key with this
INTERNAL_API_SECRET=vexa-internal-secret
VEXA_DISPATCH_SIGNING_KEY=dev-dispatch-signing-key
NEXTAUTH_SECRET=dev-nextauth-secret
# NEXTAUTH_URL — public origin when behind a domain/reverse-proxy (e.g. https://vexa.example.com).
# Required for OAuth login; an https:// value also flips the auth cookies to Secure.
NEXTAUTH_URL=

# OAuth login providers (terminal sign-in buttons). Each self-gates on its creds: set BOTH id+secret
# to expose that provider; leave empty to hide it (the dev type-any-email login always works).
# Register the redirect URI in the provider console: ${NEXTAUTH_URL}/api/auth/callback/{google|microsoft}
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common                          # "common" = work/school + personal; or an org tenant id

# Google Analytics 4 (terminal web usage). Set to your measurement id (G-XXXXXXXXXX) to turn on
# frontend analytics — page views + an `api_request` event per web-client API call. Baked into the
# client bundle at BUILD time, so rebuild the terminal image after changing it. Empty → GA stays off.
GA_MEASUREMENT_ID=

# --- CREDENTIALS — fill these for transcription + agent intelligence ---------
# Transcription (STT): self-host the bundled service (deploy/transcription — GPU or CPU,
# deployed separately from this stack) and point URL at its load balancer (base URL; the client
# appends /v1/audio/transcriptions), e.g. http://<gpu-host>:8083. TOKEN must match that unit's
# API_TOKEN. Or use a hosted token from https://vexa.ai/account. Without it, bots join + record
# but produce no transcript.
TRANSCRIPTION_SERVICE_URL=
TRANSCRIPTION_SERVICE_TOKEN=
# Deployment-level defaults for a spawn's flags when the request does not say (config.v1 `defaulted`).
# TRANSCRIBE_ENABLED=false makes a no-STT deployment spawn capture-only bots instead of 503-ing every
# default POST /bots. Both default true.
TRANSCRIBE_ENABLED=
RECORDING_ENABLED=
BOT_SPEAKER_MIN_AUDIO_SEC=
BOT_SPEAKER_SUBMIT_INTERVAL_SEC=
BOT_SPEAKER_CONFIRM_THRESHOLD=
BOT_SPEAKER_MAX_BUFFER_SEC=
BOT_SPEAKER_IDLE_TIMEOUT_SEC=
# Self-hosted Jitsi hostnames (comma-separated, e.g. calls.example.org) recognized when parsing
# pasted meeting links AND calendar (ICS) links. meet.jit.si and hosts naming "jitsi" are always
# recognized; hosts with a "meet" label (meet.example.org, eu.meet.example.org) are recognized in
# pasted links. List a host here to make its calendar invites import as joinable Jitsi meetings.
VEXA_JITSI_HOSTS=

# LLM provider for the meeting copilot's card beats (PROVIDER-AGNOSTIC — the llm module's
# CompletionPort; see core/agent/llm/README.md). openai-compat (default) works with OpenRouter,
# Ollama, vLLM, LM Studio, OpenAI, or any {base}/chat/completions endpoint; `anthropic` speaks the
# Messages dialect. Both services env_file this file, and the runtime brokers these into workers.
# Providers: openai-compat (default) | anthropic | claude-cli (beats ride the claude CLI on the
# mounted subscription credentials — no API key; slower, for subscription-only deployments).
VEXA_LLM_PROVIDER=
VEXA_LLM_BASE_URL=
VEXA_LLM_API_KEY=
VEXA_LLM_MODEL=
VEXA_LLM_MAX_TOKENS=
# Optional operator gate on workspace-pinned models (comma-separated; empty = allow any route).
VEXA_MODEL_ALLOWLIST=
# The agent HARNESS for workspace turns (chat / routines / post-meeting docs) — a CLI coding agent.
# claude-code (default) is the only adapter today; open-source runners land as new adapters.
VEXA_RUNNER=

# Credentials for the claude-code harness ONLY (unused by other runners). Without them,
# capture + transcripts work but agent chat / workspace turns do not.
# Two delivery mechanisms into spawned workers:
#   1) env passthrough — agent-api stamps the model-auth allowlist (CLAUDE_CODE_OAUTH_TOKEN,
#      ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN / ANTHROPIC_BASE_URL, VEXA_LLM_API_KEY /
#      VEXA_LLM_BASE_URL) from its own env into every dispatch spec env. Works on EVERY runtime
#      backend (docker/compose, k8s/helm, process/lite) — on helm it is the ONLY path.
#   2) HOST_CLAUDE_CREDENTIALS bind-mount (docker backend only, "optional" below) — the runtime
#      mounts a host ~/.claude/.credentials.json read-only into the worker.
# If both are configured, the claude CLI prefers its env credential over the mounted file —
# configure exactly one to avoid ambiguity.
# CLAUDE_CODE_OAUTH_TOKEN = the claude CLI subscription OAuth token (env twin of the mount).
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
VEXA_AGENT_MODEL=
VEXA_MEETING_MODEL=
VEXA_AGENT_DEFAULT_SUBJECT=u_live

# --- optional ----------------------------------------------------------------
# Bot API key — fallback auth for the terminal's proxy auth chain:
# cookie token → VEXA_API_KEY → VEXA_BOT_API_KEY → "". Set to a token minted
# by `make provision-token` (same scopes: bot,tx). Leave empty if unused.
VEXA_BOT_API_KEY=
VEXA_AGENT_SRC_MOUNT=

# Claude SUBSCRIPTION credentials for agent workers (the claude-code runner's no-API-key path).
# HOW IT WORKS (explicit + deterministic — config.v1 `model_inference` capability):
#   1. Set this to a path ON THE DOCKER HOST (not inside any container) of a claude credentials
#      JSON — typically $HOME/.claude/.credentials.json after `claude login` on the host.
#   2. The runtime bind-mounts that host file READ-ONLY into EVERY spawned agent-worker at
#      /root/.claude/.credentials.json (core/runtime docker backend); the worker's claude CLI
#      authenticates from it. No key material passes through env.
#   3. The same path is mirror-mounted into the runtime container so its config.v1 file probe can
#      verify the file exists + parses; a bad path shows as `model_inference: misconfigured` on the
#      runtime's /health (docker silently turns a missing host path into an empty directory in the
#      worker, which otherwise only surfaces as 'Model inference failed: Not logged in' at chat time).
# macOS ONLY: the CLI's real store is the login Keychain — this file is a one-time export that
# expires every ~8-12h (agent chat then 401s while `claude` still works). Install the bundled
# refresher once: deploy/bin/claude-creds-sync/install.sh (Linux/WSL2 need nothing — the CLI
# refreshes the file itself). See deploy/bin/claude-creds-sync/README.md.
# Alternative credential path: leave this empty and set ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN
# (+ ANTHROPIC_BASE_URL) above — the runtime brokers those into workers as env instead.
HOST_CLAUDE_CREDENTIALS=

# agent-api → meeting-api (SSE stream ownership check)
VEXA_MEETING_API_URL=http://meeting-api:8080

# --- gateway edge guard (fastapi-guard) ---------------------------------------
# Per-IP rate limiting + auto-IP-ban at the gateway edge. ON BY DEFAULT with generous limits
# (600 requests/min per IP) — to opt OUT, uncomment GUARD_ENABLED=false. All GUARD_* keys below
# interpolate into the gateway service via docker-compose.yml (`${VAR:-default}`), so setting any
# of them in this file takes effect on the next `docker compose up`.
# GUARD_WS_ENABLED is the optional /ws connect guard (off by default, opt-in): in-memory
# per-process — does NOT share ban/rate-limit state with the Redis-backed HTTP layer, and under
# uvicorn --workers N>1 each worker keeps an independent WS ban set. See
# core/gateway/services/gateway/src/gateway/edge_guard.py for the full GUARD_* surface.
#GUARD_ENABLED=false              # uncomment to turn the edge guard OFF
#GUARD_WS_ENABLED=false
#GUARD_ENABLE_REDIS=true          # reuse REDIS_URL for guard state (vexa:guard: namespace)
#GUARD_RATE_LIMIT_RPM=600         # per-IP requests per minute (0 disables rate limiting)
#GUARD_RATE_LIMIT_WINDOW=60
#GUARD_AUTO_BAN_THRESHOLD=10
#GUARD_AUTO_BAN_DURATION=3600
#GUARD_IP_BLACKLIST=             # comma-separated IPs to block (403)
#GUARD_IP_WHITELIST=             # comma-separated IPs to bypass the guard
#GUARD_TRUSTED_PROXIES=          # comma-separated trusted proxy IPs (enables X-Forwarded-For resolution)
#GUARD_BLOCKED_COUNTRIES=
#GUARD_BLOCK_CLOUD_PROVIDERS=
