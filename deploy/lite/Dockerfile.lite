# syntax=docker/dockerfile:1
# =============================================================================
# Vexa Lite (v0.12) — all-in-one Docker image
# =============================================================================
# The single-container analog of deploy/compose. One container runs the whole v0.12 control
# plane — gateway (:8056) · admin-api (:8001) · meeting-api (:8080) · runtime (:8090) ·
# agent-api (:8100) — over an internal redis + a shared Xvfb/PulseAudio
# stack. The runtime uses the PROCESS backend (RUNTIME_BACKEND=process): bots and agent
# workers run as CHILD PROCESSES, not docker-socket-spawned containers — so lite needs NO
# docker socket. PostgreSQL + MinIO are external (the `make lite` sidecars).
#
# Self-contained: built on the official Playwright image (the bot pins playwright 1.56.0) and
# installs its own browser/X11/audio stack — it does NOT depend on the bot's published
# meet-join-env base. The bot workspace is built from source in the bot-builder stage below.
#
#   Build:  docker build -f deploy/lite/Dockerfile.lite -t vexa-lite:dev .   (context = repo root)
#   Run:    see deploy/lite/Makefile (`make lite`)
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: bot-builder — build the @vexa/bot workspace slice from source.
# Mirrors core/meetings/services/bot/Dockerfile (builder), but on the official Playwright
# image instead of the published meet-join-env base. Browsers come from /ms-playwright.
# -----------------------------------------------------------------------------
FROM mcr.microsoft.com/playwright:v1.56.0-jammy AS bot-builder
ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    CI=1
RUN corepack enable && corepack prepare pnpm@11.7.0 --activate && pnpm --version

WORKDIR /build
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json turbo.json ./
COPY core ./core
COPY scripts ./scripts
RUN --mount=type=cache,id=pnpm-store-lite,target=/pnpm/store \
    pnpm install --frozen-lockfile=false
# Build the page-side capture bricks first (browser bundles, not bot deps), then @vexa/bot + deps.
RUN pnpm --filter "@vexa/capture-codec" --filter "@vexa/gmeet-capture" --filter "@vexa/mixed-capture-core" --filter "@vexa/record-chunker" --filter "@vexa/jitsi-capture" --filter "@vexa/teams-capture" --filter "@vexa/zoom-capture" run build
RUN pnpm --filter "@vexa/bot..." run build
RUN test -f /build/core/meetings/services/bot/dist/index.js \
 && test -s /build/core/meetings/services/bot/dist/browser-utils.global.js
# Mixed-lane (Zoom/Teams) diarization model — best-effort; the gmeet lane never loads it, so a
# restricted-network build still succeeds (the lane simply downloads on first use if reachable).
ENV VEXA_HF_CACHE=/opt/hf-cache
RUN cd /build && node core/meetings/services/bot/warm-hf-cache.mjs || echo "[bot-builder] HF cache warm skipped"

# -----------------------------------------------------------------------------
# Stage 2b: terminal-builder — the agent-domain workbench (clients/terminal). A Next.js app run
# under its OWN custom server (server.mjs: SSE relay + /ws upgrade proxy), so we keep the full
# runtime node_modules (npm prune --omit=dev) rather than a standalone trace. Built on the SAME
# Playwright base as the final stage so any native addon (ws' bufferutil) is ABI-compatible.
# -----------------------------------------------------------------------------
FROM mcr.microsoft.com/playwright:v1.56.0-jammy AS terminal-builder
WORKDIR /app/terminal
COPY clients/terminal/package.json clients/terminal/package-lock.json ./
RUN npm ci --no-audit --no-fund
COPY clients/terminal/ ./
# next build needs the dev deps (typescript/tailwind); prune them after so the runtime tree is lean.
RUN npm run build && npm prune --omit=dev

# -----------------------------------------------------------------------------
# Stage 3: final — assemble the all-in-one runtime image on the same Playwright base.
# -----------------------------------------------------------------------------
FROM mcr.microsoft.com/playwright:v1.56.0-jammy AS final
ENV DEBIAN_FRONTEND=noninteractive

# System stack: Python (the 5 services) · supervisor · redis · X11/audio (Xvfb/fluxbox/pulse) ·
# noVNC (browser view) · postgres client (pg_isready) · git (agent governance ops).
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 python3-pip python3-venv python3-dev build-essential \
      supervisor redis-server postgresql-client \
      xvfb fluxbox x11vnc novnc python3-websockify \
      pulseaudio xdotool xclip socat ffmpeg libsndfile1 \
      curl git ca-certificates \
 && usermod -aG pulse-access root 2>/dev/null || true \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

# uv (the per-service venvs are resolved from each service's own pyproject + uv.lock).
RUN pip3 install --no-cache-dir uv==0.9.22

ENV UV_LINK_MODE=copy \
    PYTHONUNBUFFERED=1 \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    DISPLAY=:99

WORKDIR /app
RUN mkdir -p /var/log/supervisor /var/lib/redis /var/run/redis /workspaces

# ── Python venvs — one per service (avoids cross-service dependency-pin conflicts). Each mirrors
#    that service's Dockerfile (uv sync --frozen + the production-only ASGI/DB extras). ────────────
#    `--python 3.12` pins the interpreter to match every compose image's `FROM python:3.12-slim`.
#    The jammy base ships only system python3.10 (< requires-python >=3.11), so an unpinned
#    `uv venv` would auto-download the newest managed CPython (3.14) — whose stack fails at boot
#    (SQLAlchemy's psycopg dialect import). Pinning keeps Lite on the same interpreter as compose/helm.
# admin-api
COPY core/identity/services/admin-api/pyproject.toml core/identity/services/admin-api/uv.lock /tmp/admin/
RUN cd /tmp/admin && uv venv --python 3.12 /opt/venvs/admin \
 && UV_PROJECT_ENVIRONMENT=/opt/venvs/admin uv sync --frozen --no-install-project \
 && uv pip install --python /opt/venvs/admin/bin/python "uvicorn[standard]==0.34.0" "sqlalchemy[asyncio]==2.0.36" "asyncpg==0.30.0"
# runtime
COPY core/runtime/pyproject.toml core/runtime/uv.lock /tmp/runtime/
RUN cd /tmp/runtime && uv venv --python 3.12 /opt/venvs/runtime \
 && UV_PROJECT_ENVIRONMENT=/opt/venvs/runtime uv sync --frozen --no-install-project --no-dev \
 && uv pip install --python /opt/venvs/runtime/bin/python "uvicorn[standard]==0.34.0"
# meeting-api
COPY core/meetings/services/meeting-api/pyproject.toml core/meetings/services/meeting-api/uv.lock /tmp/meeting/
RUN cd /tmp/meeting && uv venv --python 3.12 /opt/venvs/meeting \
 && UV_PROJECT_ENVIRONMENT=/opt/venvs/meeting uv sync --frozen --no-install-project \
 && uv pip install --python /opt/venvs/meeting/bin/python "uvicorn[standard]==0.34.0" "sqlalchemy[asyncio]==2.0.36" "asyncpg==0.30.0" "boto3==1.35.0"
# gateway
COPY core/gateway/services/gateway/pyproject.toml core/gateway/services/gateway/uv.lock /tmp/gateway/
RUN cd /tmp/gateway && uv venv --python 3.12 /opt/venvs/gateway \
 && UV_PROJECT_ENVIRONMENT=/opt/venvs/gateway uv sync --frozen --no-install-project \
 && uv pip install --python /opt/venvs/gateway/bin/python "uvicorn[standard]==0.34.0" "redis==5.2.1"
# agent (control-plane group ⇒ fastapi/uvicorn; base deps cover the worker too)
COPY core/agent/pyproject.toml core/agent/uv.lock /tmp/agent/
RUN cd /tmp/agent && uv venv --python 3.12 /opt/venvs/agent \
 && UV_PROJECT_ENVIRONMENT=/opt/venvs/agent uv sync --frozen --no-install-project --no-default-groups --group control-plane
RUN rm -rf /tmp/admin /tmp/runtime /tmp/meeting /tmp/gateway /tmp/agent

# Claude Code (the agent worker's model+tooling runtime) — npm global, on PATH for every spawned worker.
RUN npm install -g @anthropic-ai/claude-code

# ── Service source + the sealed contracts each loads BY PATH (layout mirrors each service image,
#    re-rooted under /app/<service> so the import walk-up resolves the same relative tree). ────────
# admin-api  (PYTHONPATH=/app/admin-api/src)
COPY core/identity/services/admin-api/src /app/admin-api/src
# runtime    (PYTHONPATH=/app/runtime/src)
COPY core/runtime/src /app/runtime/src
# gateway    (PYTHONPATH=/app/gateway/src)
COPY core/gateway/services/gateway/src /app/gateway/src
# meeting-api (PYTHONPATH=/app/meeting-api/src; repo_root walk-up == /app/meeting-api)
COPY core/meetings/services/meeting-api/src /app/meeting-api/src
COPY core/meetings/contracts/invocation.v1/invocation.schema.json /app/meeting-api/meetings/contracts/invocation.v1/invocation.schema.json
COPY core/meetings/contracts/lifecycle.v1/lifecycle.schema.json   /app/meeting-api/meetings/contracts/lifecycle.v1/lifecycle.schema.json
COPY core/meetings/contracts/webhook.v1/webhook.schema.json       /app/meeting-api/meetings/contracts/webhook.v1/webhook.schema.json
COPY core/runtime/contracts/runtime.v1/runtime.schema.json        /app/meeting-api/runtime/contracts/runtime.v1/runtime.schema.json
COPY core/runtime/contracts/schedule.v1/schedule.schema.json      /app/meeting-api/runtime/contracts/schedule.v1/schedule.schema.json
# agent control plane + worker (PYTHONPATH=/app/agent; repo_root walk-up == /app/agent).
# This tree mirrors the WORKER image's /app layout (core/agent/worker/Dockerfile): worker + llm +
# shared + contracts + the seed registries. llm/ is LOAD-BEARING — worker.py's first import is
# `from llm import …`; omitting it kills every agent dispatch with ModuleNotFoundError.
COPY core/agent/shared          /app/agent/shared
COPY core/agent/control_plane   /app/agent/control_plane
COPY core/agent/worker          /app/agent/worker
COPY core/agent/llm             /app/agent/llm
COPY core/agent/contracts       /app/agent/contracts
COPY core/agent/workspace-seeds /app/agent/workspace-seeds
COPY core/agent/tools-seed      /app/agent/tools-seed
COPY core/meetings/contracts/transcript.v1/transcript.schema.json /app/agent/meetings/contracts/transcript.v1/transcript.schema.json
COPY core/agent/contracts/workspace.v1/workspace.schema.json      /app/agent/agent/contracts/workspace.v1/workspace.schema.json
COPY core/agent/contracts/invoke.v1/invoke.schema.json            /app/agent/agent/contracts/invoke.v1/invoke.schema.json
COPY core/agent/contracts/unit.v1/unit.schema.json                /app/agent/agent/contracts/unit.v1/unit.schema.json
COPY core/agent/contracts/routine.v1/routine.schema.json          /app/agent/agent/contracts/routine.v1/routine.schema.json
COPY core/agent/contracts/event.v1/event.schema.json              /app/agent/agent/contracts/event.v1/event.schema.json
COPY core/agent/contracts/tool.v1/tool.schema.json                /app/agent/agent/contracts/tool.v1/tool.schema.json
# Build-time guard: the curated /app/agent tree must import as the worker the launcher execs
# (vexa-agent-worker → `python -m worker`). Catches an incomplete copy — the exact bug class that
# shipped a tree without llm/ and killed every chat dispatch — at build time, not first dispatch.
RUN cd /app/agent && PYTHONPATH=/app/agent /opt/venvs/agent/bin/python -c "import worker.worker"

# ── Bot workspace (built tree) — placed at /app so the bot resolves /app/browser-utils.global.js
#    and its package-relative schema/deps exactly as in the bot container. The runtime spawns it
#    via /usr/local/bin/vexa-bot-launch (cd /app/core/meetings/services/bot && node dist/index.js). ─
COPY --from=bot-builder /build/core              /app/core
COPY --from=bot-builder /build/node_modules      /app/node_modules
COPY --from=bot-builder /build/package.json /build/pnpm-workspace.yaml /build/pnpm-lock.yaml /build/tsconfig.base.json /build/turbo.json /app/
COPY --from=bot-builder /build/core/meetings/services/bot/dist/browser-utils.global.js /app/browser-utils.global.js
COPY --from=bot-builder /opt/hf-cache /opt/hf-cache
ENV VEXA_HF_CACHE=/opt/hf-cache
# License hygiene: the baked weights are onnx-community/pyannote-segmentation-3.0
# (MIT). Ship the copyright + permission notice next to the cache so it travels
# with the software. Recorded in repo THIRD_PARTY_LICENSES.md + the per-release
# SPDX SBOM (scripts/sbom.mjs); model weights sit outside gate:licenses.
COPY licenses/onnx-community-pyannote-segmentation-3.0.LICENSE.txt /opt/hf-cache/LICENSE.pyannote-segmentation-3.0


# ── Terminal (Next.js + custom server.mjs) → /app/terminal (supervisord runs `node server.mjs`). ──
COPY --from=terminal-builder /app/terminal /app/terminal

# ── Launchers, supervisor config, entrypoint ──────────────────────────────────────────────────────
COPY deploy/lite/bin/vexa-bot-launch deploy/lite/bin/vexa-agent-worker deploy/lite/bin/setup-pulseaudio-sinks.sh deploy/lite/bin/provision-key.sh /usr/local/bin/
COPY deploy/lite/supervisord.conf /etc/supervisor/conf.d/vexa.conf
COPY deploy/lite/entrypoint.sh /entrypoint.sh
RUN chmod +x /usr/local/bin/vexa-bot-launch /usr/local/bin/vexa-agent-worker \
      /usr/local/bin/setup-pulseaudio-sinks.sh /usr/local/bin/provision-key.sh /entrypoint.sh

# ── Env defaults (every var supervisord interpolates must be SET; entrypoint derives the rest) ────
ENV LOG_LEVEL=info \
    RUNTIME_BACKEND=process \
    BOT_COMMAND=/usr/local/bin/vexa-bot-launch \
    AGENT_WORKER_COMMAND=/usr/local/bin/vexa-agent-worker \
    DB_HOST=localhost DB_PORT=5432 DB_NAME=vexa DB_USER=postgres DB_PASSWORD=postgres \
    REDIS_HOST=localhost REDIS_PORT=6379 \
    ADMIN_API_TOKEN=changeme INTERNAL_API_SECRET=lite-internal-secret \
    TRANSCRIPTION_SERVICE_URL= TRANSCRIPTION_SERVICE_TOKEN= \
    MINIO_ENDPOINT= MINIO_ACCESS_KEY= MINIO_SECRET_KEY= MINIO_BUCKET=vexa MINIO_SECURE=false \
    VEXA_AGENT_DEFAULT_SUBJECT=u_live VEXA_DISPATCH_SIGNING_KEY=dev-dispatch-signing-key \
    VEXA_BOT_API_KEY= VEXA_AGENT_MODEL= VEXA_MEETING_MODEL= HOST_CLAUDE_CREDENTIALS= \
    ANTHROPIC_API_KEY= ANTHROPIC_AUTH_TOKEN= ANTHROPIC_BASE_URL= ANTHROPIC_MODEL= \
    ANTHROPIC_DEFAULT_OPUS_MODEL= ANTHROPIC_DEFAULT_SONNET_MODEL= ANTHROPIC_DEFAULT_HAIKU_MODEL= \
    VEXA_PUBLIC_API_URL=http://localhost:8056 VEXA_API_KEY= \
    TERMINAL_PUBLIC_URL=http://localhost:3001 \
    NEXTAUTH_SECRET=vexa-lite-nextauth-secret JWT_SECRET=vexa-lite-jwt-secret

# Front doors: gateway (8056) · terminal (3001) · agent control plane (8100).
EXPOSE 8056 3001 8100 6080

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -sf http://localhost:8056/health > /dev/null || exit 1

ENTRYPOINT ["/entrypoint.sh"]
CMD ["supervisord", "-n", "-c", "/etc/supervisor/conf.d/vexa.conf"]
