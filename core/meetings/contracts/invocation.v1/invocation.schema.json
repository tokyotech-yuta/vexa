{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vexa.ai/schemas/invocation.v1",
  "title": "invocation.v1",
  "description": "The meeting-bot's constructor — delivered as one JSON env var VEXA_BOT_CONFIG (ADR-0002), validated at boot. A config contract legitimately carries the secrets the bot needs (marked SECRET below; placeholders in goldens, P14). No tenancy fields (deferred, ADR-0003).",
  "$defs": {
    "Platform": { "enum": ["google_meet", "zoom", "teams", "jitsi"] },
    "AutomaticLeave": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "waitingRoomTimeout": { "type": "integer", "default": 300000 },
        "noOneJoinedTimeout": { "type": "integer", "default": 600000 },
        "everyoneLeftTimeout": { "type": "integer", "default": 120000 }
      }
    },
    "Invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "meetingUrl", "botName", "redisUrl"],
      "properties": {
        "platform": { "$ref": "#/$defs/Platform" },
        "meetingUrl": { "type": ["string", "null"], "description": "null only for native-SDK zoom" },
        "botName": { "type": "string" },
        "passcode": { "type": "string", "description": "meeting passcode (zoom passcode screen / jitsi room password); placeholder in goldens" },
        "nativeMeetingId": { "type": "string" },
        "token": { "type": "string", "description": "SECRET — MeetingToken; placeholder in goldens" },
        "connectionId": { "type": "string" },
        "meeting_id": { "type": "integer" },
        "container_name": { "type": "string" },
        "redisUrl": { "type": "string", "description": "acts.v1 bus + transcript egress" },
        "meetingApiCallbackUrl": { "type": "string", "format": "uri", "description": "lifecycle.v1 sink" },
        "internalSecret": { "type": "string", "description": "SECRET; placeholder in goldens" },
        "language": { "type": ["string", "null"] },
        "task": { "type": ["string", "null"] },
        "allowedLanguages": { "type": "array", "items": { "type": "string" } },
        "transcribeEnabled": { "type": "boolean" },
        "transcriptionTier": { "enum": ["realtime", "deferred"] },
        "transcriptionServiceUrl": { "type": "string", "description": "stt endpoint" },
        "transcriptionServiceToken": { "type": "string", "description": "SECRET; placeholder in goldens" },
        "transcriptionModel": { "type": ["string", "null"], "description": "stt model id sent as the OpenAI-compatible `model` form part; unset → whisper-1" },
        "recordingEnabled": { "type": "boolean" },
        "captureSignalEnabled": { "type": "boolean", "description": "tee the raw captured-signal.v1 stream (audio frames + speaker events) to durable storage for offline replay (O-TEL-1); the transcript/recording paths are unaffected either way" },
        "captureModes": { "type": "array", "items": { "type": "string" } },
        "recordingUploadUrl": { "type": "string", "format": "uri", "description": "recording sink" },
        "automaticLeave": { "$ref": "#/$defs/AutomaticLeave" },
        "reconnectionIntervalMs": { "type": "integer" },
        "voiceAgentEnabled": { "type": "boolean", "description": "gates the acts.v1 voice commands" },
        "defaultAvatarUrl": { "type": "string", "format": "uri" },
        "videoReceiveEnabled": { "type": "boolean" },
        "cameraEnabled": { "type": "boolean" },
        "authenticated": { "type": "boolean", "description": "persistent browser context from S3" },
        "userdataS3Path": { "type": "string" },
        "s3Endpoint": { "type": "string" },
        "s3Bucket": { "type": "string" },
        "s3AccessKey": { "type": "string", "description": "SECRET; placeholder in goldens" },
        "s3SecretKey": { "type": "string", "description": "SECRET; placeholder in goldens" }
      }
    }
  }
}
